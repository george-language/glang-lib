# file debug.glang: tools for debugging objects

# assert that an expression is true (throws an error if false)
# returns null
func assert(expr) {
    if expr != true {
        uhoh("assertion failed, resulting expression was not true");
    }
}

# assert that a == b (throws an error if false)
# returns null
func assert_eq(a, b) {
    if a != b {
        uhoh("assertion failed, a != b");
    }
}
